# ============================================
# CONFIGURACIÓN SGMOT API
# ============================================

# Google OAuth (backend)
# Obtener en: https://console.cloud.google.com/
# En desarrollo local, puede estar vacío si frontend/.env.local lo tiene configurado
GOOGLE_CLIENT_ID=

# ============================================
# SEGURIDAD - CRÍTICO PARA PRODUCCIÓN
# ============================================

# JWT_SECRET: Clave para firmar tokens JWT
# DEBE ser: cadena aleatoria de 32+ caracteres (base64, hexadecimal, o alfanumérica)
# Generar con: openssl rand -base64 32
# ⚠️ CAMBIAR ANTES DE PRODUCCIÓN - tokens comprobables sin un secreto fuerte
JWT_SECRET=CAMBIAR_ESTO_CON_CADENA_ALEATORIA_32_CARACTERES_MINIMO

# CORS_ALLOWED_ORIGIN: Origen permitido para solicitudes CORS
# Desarrollo: http://localhost:5173
# Producción: https://tudominio.com (sin trailing slash)
# ⚠️ NO usar * en producción
CORS_ALLOWED_ORIGIN=http://localhost:5173

# APP_TIMEZONE: Zona horaria del sistema
APP_TIMEZONE=America/Lima

# ============================================
# BASE DE DATOS
# ============================================

# MySQL/MariaDB
DB_HOST=localhost
DB_NAME=sgmot
DB_USER=root
DB_PASSWORD=

# MySQL connection timezone
DB_TIME_ZONE=-05:00

# ============================================
# NOTAS DE SEGURIDAD
# ============================================

# 1. Cambiar JWT_SECRET a valor aleatorio fuerte (32+ caracteres)
# 2. Usar HTTPS en producción (certificado SSL/TLS)
# 3. Restringir CORS_ALLOWED_ORIGIN al dominio específico
# 4. Usar contraseña fuerte para DB_PASSWORD en producción
# 5. Validar que PHP tiene librerías: openssl, curl, mysqli/pdo, mbstring, gd
# 6. Revisar logs regularmente en /var/log/ o {APP_DIR}/logs/
# 7. Mantener backups de la base de datos
# 8. Usar variables de entorno, no hardcodear en config
# 9. Activar HSTS y CSP en producción
# 10. Realizar auditoría de seguridad antes de lanzar a producción
