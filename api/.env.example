# SGMOT API - Production environment example

# development | production
APP_ENV=production

# Google OAuth backend Client ID. It must match the frontend Client ID.
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# Generate with: openssl rand -base64 48
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_DE_48_BYTES

# Exact frontend origin, no trailing slash.
CORS_ALLOWED_ORIGIN=https://tudominio.com

APP_TIMEZONE=America/Lima

DB_HOST=localhost
DB_NAME=sgmot
DB_USER=sgmot_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE
DB_TIME_ZONE=-05:00
