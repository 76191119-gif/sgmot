# ============================================================
# Configuración SGMOT - Frontend
# ============================================================
# Copia este archivo como .env.local y completa con tus valores.

# URL base del API PHP (sin slash final)
VITE_API_URL=http://localhost/sgmot/api

# Google OAuth Client ID (opcional - para login con Google).
# Obtén uno gratis en https://console.cloud.google.com/apis/credentials
# Si dejas esto vacío, el botón "Continuar con Google" se ocultará.
# Inserta aquí tu Client ID real para activar el login con Google.
VITE_GOOGLE_CLIENT_ID=

# Solo para pruebas locales con el Client ID demo del codigo.
VITE_ALLOW_GOOGLE_DEMO=false
